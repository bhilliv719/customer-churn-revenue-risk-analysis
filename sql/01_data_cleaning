## Validate data
select *
From `charming-bolt-464216-v0.saas_churn_analysis.customer_churn`
limit 10;

## Step 2: Data Quality Audit

  # Row count
Select Count(*) as total_rows
from `charming-bolt-464216-v0.saas_churn_analysis.customer_churn`;

  # Duplicate Customer IDs
Select 
    customerID,
    count(*) as occurrences
from `charming-bolt-464216-v0.saas_churn_analysis.customer_churn`
group by customerID
having count(*) > 1;

  #Missing values 
SELECT
    COUNTIF(customerID IS NULL) AS customerID_nulls,
    COUNTIF(tenure IS NULL) AS tenure_nulls,
    COUNTIF(MonthlyCharges IS NULL) AS monthly_nulls,
    COUNTIF(TotalCharges IS NULL) AS total_nulls,
    COUNTIF(Churn IS NULL) AS churn_nulls
FROM `charming-bolt-464216-v0.saas_churn_analysis.customer_churn`;

  #Check totalchargers
select *
from `charming-bolt-464216-v0.saas_churn_analysis.customer_churn`
where trim(TotalCharges) = '';


## Step 3: Create Clean Table
CREATE OR Replace TABLE `charming-bolt-464216-v0.saas_churn_analysis.customer_churn_clean` AS
SELECT
    customerID,
    gender,
    SeniorCitizen,
    Partner,
    Dependents,
    tenure,
    PhoneService,
    MultipleLines,
    InternetService,
    OnlineSecurity,
    OnlineBackup,
    DeviceProtection,
    TechSupport,
    StreamingTV,
    StreamingMovies,
    Contract,
    PaperlessBilling,
    PaymentMethod,
    MonthlyCharges,
    SAFE_CAST(NULLIF(TRIM(TotalCharges), '') AS FLOAT64) AS TotalCharges,
    Churn
FROM `charming-bolt-464216-v0.saas_churn_analysis.customer_churn`;

## Step 4: Create business segments
create or replace table `charming-bolt-464216-v0.saas_churn_analysis.customer_churn_enriched` as 
select 
  *,
  case 
    when tenure < 12 then 'New'
    when tenure < 36 then 'Established'
    else 'loyal'
  End as tenure_segment
From `charming-bolt-464216-v0.saas_churn_analysis.customer_churn_clean`;

## Step 5: First Executive KPI Query

SELECT
    COUNT(*) AS total_customers,
    SUM(CASE WHEN Churn THEN 1 ELSE 0 END) AS churned_customers,
    ROUND(100 * SUM(CASE WHEN Churn THEN 1 ELSE 0 END) / COUNT(*), 2) AS churn_rate_percent,
    ROUND(SUM(MonthlyCharges), 2) AS monthly_revenue
FROM `charming-bolt-464216-v0.saas_churn_analysis.customer_churn_enriched`;

